# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_sales_executive?schema=public"

# Secret used to sign the dummy-login JWT cookie. Use a long random string in real deployments.
JWT_SECRET="dev-only-secret-change-me"

# Public base URL of this app (no trailing slash). Used to build the
# Instagram OAuth redirect URI.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Meta App credentials — from developers.facebook.com, "Instagram" product,
# "API setup with Instagram login". App ID/Secret live on the app's
# Basic Settings page.
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# Must exactly match one of the "Valid OAuth Redirect URIs" configured on
# the Instagram product page in the Meta App Dashboard.
INSTAGRAM_REDIRECT_URI="http://localhost:3000/api/auth/instagram/callback"

# Any random string you choose. Enter the same value in the Meta App
# Dashboard's Webhooks product when subscribing this app's callback URL,
# and Meta will echo it back on the verification handshake.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN="choose-a-random-string"
